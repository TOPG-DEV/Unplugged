# Unplugged // OPERATOR — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# ----- MongoDB -----
# Canonical DB name is `unpluggedDB`. The URI should NOT hardcode the DB name.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ----- Solana RPC (client-exposed — cannot be hidden; see 01-RESEARCH.md) -----
# Recommended: Helius RPC with origin restrictions set in Helius dashboard.
# Example: https://mainnet.helius-rpc.com/?api-key=<your-key>
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<helius-public-rpc-key>

# ----- Helius (server-only — DO NOT add NEXT_PUBLIC_ prefix) -----
# Used server-side by /api/verify-wallet, /api/trending, /api/token-balance, /api/wallet-activity.
HELIUS_API_KEY=<helius-server-key>

# Shared secret set when creating a Helius webhook (Phase 2 TRACK-01).
# Stored in both Helius dashboard and here; backend compares Authorization header to this.
HELIUS_WEBHOOK_SECRET=<generate-32-char-random-string>

# ----- Vercel Blob -----
# Rotate if leaked. Scope: Read+Write.
BLOB_READ_WRITE_TOKEN=<vercel-blob-token>

# ----- Server signer keypair (Vercel-only, never written to local disk) -----
# Stringified JSON array of 64 bytes. Generated by scripts/generate-wallets.sh Task 4.
# Not part of local dev .env — set this in Vercel env vars only.
# SOLANA_SERVER_KEYPAIR=[123,45,...,67]

# ----- Wallet addresses (public, safe to expose) -----
# Filled from .planning/ops/wallets.md after Plan 01-01 generates new wallets.
NEXT_PUBLIC_TREASURY_WALLET=<new-treasury-pubkey>
NEXT_PUBLIC_KC_CALL_WALLET=<new-kc-call-pubkey>

# ----- Tracker (Phase 2) -----
# Shared secret for Vercel Cron authentication.  Generate with `openssl rand -hex 32`.
# Set the SAME value in Vercel env vars AND in your local .env for dev.
CRON_SECRET=<generate-32-byte-hex>

# Optional: override the tracked-wallets list via env (useful for prod where
# .planning/ops/tracked-wallets.md may not be deployed).  JSON string.
# Example: [{"alias":"wallet-01","pubkey":"As7Hj..."}]
# TRACKED_WALLETS=

# ----- Trending (Phase 3 AI-01) -----
# No new env vars. Reuses HELIUS_API_KEY and CRON_SECRET from Phase 1/2.
# Optional override: KOL_WALLETS (JSON array of {alias, pubkey}) — mirrors TRACKED_WALLETS pattern.
# If unset, aggregator reads .planning/ops/kol-wallets.md at request time.
# KOL_WALLETS=

# ----- Fuel Prime (Phase 3 FUEL-01) -----
# All server-only. Never prefix with NEXT_PUBLIC_.

# @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=<bot-token-from-botfather>

# openssl rand -hex 32 — set the SAME value here and in Telegram setWebhook secret_token param
TELEGRAM_WEBHOOK_SECRET=<generate-32-byte-hex>

# Numeric chat ID of the gated Unplugged group. Negative number. Get via @RawDataBot in the group.
# Example: -1001234567890
TELEGRAM_GATED_GROUP_CHAT_ID=<gated-group-chat-id>

# CSV of wallet pubkeys allowed to request an invite. Operator-curated allowlist is the
# permanent gating anchor — no NFT Pass. Operator maintains this list directly (add OG
# contributors, vouched operators, etc).
# Example: abc123...,def456...,ghi789...
FUEL_INVITE_WALLETS=<comma-separated-wallet-pubkeys>

# platform.claude.com API key. Set a $20/mo spend limit.
ANTHROPIC_API_KEY=<anthropic-api-key>

# ----- Quick Trade (Phase 3 TRADE-01) -----
# No new env vars. Jupiter free tier via api.jup.ag/swap/v1/* requires no key for browser calls.
# Migration note: /swap/v1/* is the current stable endpoint; /swap/v2/* is the successor.
# Before 30 June 2026 (lite-api.jup.ag sunset), migrate to /swap/v2/order + /swap/v2/execute
# and expect an x-api-key header requirement. One-day refactor when the time comes.

# ----- Legacy vars (retired — do NOT re-add) -----
# NEXT_PUBLIC_RECIPIENT_WALLET — retired (old address 5ion...RcQm)
# NEXT_PUBLIC_HELIUS_API_KEY — REMOVED; moved to server-only HELIUS_API_KEY above
# NEXT_PUBLIC_PRESALE_USD_AMOUNT — retired (no $100 gate in v2)
# NEXT_PUBLIC_TOKEN_USD_PRICE — retired (no presale in v1a)
